---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ArticleHeader from '@components/ArticleHeader.astro';
import TableOfContents from '@components/TableOfContents.astro';
import RelatedPosts from '@components/RelatedPosts.astro';
import Disclaimer from '@components/Disclaimer.astro';
import ContentMeta from '@components/ContentMeta.astro';
import FAQStructuredData from '@components/FAQStructuredData.astro';
import StructuredData from '@components/StructuredData.astro';
import { TOPIC_LABELS } from '@lib/constants';
import type { TopicSlug } from '@lib/types';

interface Props {
  title: string;
  description: string;
  category: TopicSlug;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  readingTime?: number;
  currentSlug: string;
  noindex?: boolean;
}

const {
  title,
  description,
  category,
  pubDate,
  updatedDate,
  tags,
  readingTime,
  currentSlug,
  noindex,
} = Astro.props;

const fullTitle = `${title} | BVI.vg`;
---

<BaseLayout title={fullTitle} description={description} noindex={noindex}>
  <StructuredData type="Article" data={{
    headline: title,
    description: description,
    datePublished: pubDate.toISOString(),
    dateModified: (updatedDate || pubDate).toISOString(),
    author: { '@type': 'Organization', name: 'BVI.vg' },
  }} />
  <StructuredData type="BreadcrumbList" data={{
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首页', item: 'https://bvi.vg/' },
      { '@type': 'ListItem', position: 2, name: TOPIC_LABELS[category], item: `https://bvi.vg/${category}/` },
      { '@type': 'ListItem', position: 3, name: title },
    ],
  }} />
  <div class="max-w-(--page-max-width) mx-auto px-6 py-10">
    <Breadcrumbs category={category} title={title} />

    <div class="lg:flex lg:gap-10">
      <!-- Main content -->
      <div class="flex-1 min-w-0 max-w-(--content-max-width)">
        <ArticleHeader
          title={title}
          category={category}
          pubDate={pubDate}
          updatedDate={updatedDate}
          tags={tags}
          readingTime={readingTime}
        />

        <!-- Mobile TOC -->
        <details class="toc-mobile mb-8 lg:hidden bg-bg-muted rounded-lg border border-border-main">
          <summary class="px-4 py-3 font-sans text-sm font-medium cursor-pointer">目录</summary>
          <div id="toc-mobile-container" class="px-4 pb-4"></div>
        </details>

        <div class="prose">
          <slot />
        </div>

        <Disclaimer />
        <ContentMeta
          pubDate={pubDate}
          updatedDate={updatedDate}
        />
        <RelatedPosts currentSlug={currentSlug} category={category} tags={tags} />
      </div>

      <!-- Desktop sidebar TOC -->
      <aside class="toc-desktop hidden lg:block w-(--sidebar-width) shrink-0">
        <div class="sticky top-[calc(var(--nav-height)+2rem)]">
          <TableOfContents />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
