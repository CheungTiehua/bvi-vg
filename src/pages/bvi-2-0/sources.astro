---
import BaseLayout from '@layouts/BaseLayout.astro';
import BVI20SectionNav from '@components/BVI20SectionNav.astro';

const sourceGroups = [
  {
    title: 'BVI 官方机构',
    items: [
      'BVI Financial Services Commission (FSC)',
      'BVI International Tax Authority (ITA)',
      'BVI Government',
    ],
  },
  {
    title: '国际监管与税务透明',
    items: [
      'OECD 自动信息交换与 CRS / CARF 资料',
      'FATF 加强监控司法管辖区资料',
      'EU Council 税务非合作管辖名单资料',
    ],
  },
  {
    title: '中国相关官方资料',
    items: [
      '国家税务总局公开资料',
      '国家外汇管理局公开资料',
    ],
  },
];
---

<BaseLayout title="官方来源 | BVI 2.0 | BVI.vg" description="BVI 2.0 官方来源导航：BVI 官方机构、国际监管机构与中国税务外汇公开资料。">
  <div class="max-w-(--content-max-width) mx-auto px-6 py-10">
    <nav aria-label="面包屑" class="mb-6">
      <ol class="flex items-center gap-1.5 text-sm font-sans text-text-muted">
        <li><a href="/" class="hover:text-primary transition-colors">首页</a></li>
        <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li><a href="/bvi-2-0/" class="hover:text-primary transition-colors">BVI 2.0</a></li>
        <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-text-main">官方来源</li>
      </ol>
    </nav>

    <article class="prose">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-sans font-medium bg-secondary/10 text-secondary-dark mb-4">BVI 2.0 · Sources</span>
      <h1>官方来源</h1>
      <p class="lead">BVI 2.0 板块以公开官方资料为基础。本页汇总后续维护中最常用的官方来源类别，便于核验法规、公告与国际监管状态。</p>

      <BVI20SectionNav />

      <div class="not-prose space-y-6 my-8">
        {sourceGroups.map((group) => (
          <section class="rounded-xl border border-border-main bg-bg-elevated p-6">
            <h2 class="font-sans text-xl font-bold text-primary mb-4">{group.title}</h2>
            <ul class="m-0 p-0 list-none space-y-2">
              {group.items.map((item) => (
                <li class="flex gap-2 text-sm text-text-muted">
                  <span class="text-secondary-dark">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>

      <h2>维护原则</h2>
      <ul>
        <li>涉及 BVI 法规状态时，优先核验 BVI FSC、BVI ITA 与 BVI Government。</li>
        <li>涉及 CRS、CARF、FATF 与欧盟名单时，优先核验 OECD、FATF 与 EU Council。</li>
        <li>涉及中国税务和外汇问题时，优先核验国家税务总局和国家外汇管理局公开资料。</li>
      </ul>
    </article>

    <aside class="mt-12 p-5 rounded-lg bg-bg-muted border border-border-main text-sm text-text-muted" role="note">
      <p class="font-sans font-semibold text-text-main mb-2">免责声明</p>
      <p>本页为公开资料导航，不代表相关机构对 BVI.vg 的授权、认可或背书。</p>
    </aside>
  </div>
</BaseLayout>
