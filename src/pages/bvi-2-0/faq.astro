---
import BaseLayout from '@layouts/BaseLayout.astro';
import BVI20SectionNav from '@components/BVI20SectionNav.astro';

const groups = [
  {
    title: 'CRS 2.0',
    questions: [
      ['CRS 2.0 是新税种吗？', '不是。CRS 2.0 是税务信息自动交换框架的升级，不直接创造新的税种，也不直接改变各国税收管辖权。'],
      ['CRS 2.0 会导致自动补税吗？', '不会自动补税。信息交换只是让税务机关获得更多账户和控制人信息，是否产生税务处理仍取决于具体税法、收入性质和申报情况。'],
      ['加密资产会被纳入 CRS 2.0 吗？', 'CRS 2.0 与 CARF 的重要变化之一，就是把加密资产相关信息纳入更透明的报告框架。合规持有的重点是身份、账户和资金来源一致。'],
    ],
  },
  {
    title: 'UBO 与信息透明',
    questions: [
      ['BVI 信息是不是全部公开了？', '不是。UBO 申报主要是向注册代理和监管体系备案，不等于公众公开查册。第三方查询也需要满足门槛、正当利益和审查程序。'],
      ['第三方能查到哪些信息？', '通常是有限范围的信息，例如姓名、国籍、权益比例等，不等于地址、证件细节和完整资产信息全部公开。具体范围以当时适用规则为准。'],
      ['UBO 门槛降低有什么影响？', '门槛降低意味着更多持股或控制比例较低的自然人需要进入备案范围。对合规用户而言，重点是及时更新注册代理处的最终受益人资料。'],
    ],
  },
  {
    title: 'FATF 与银行开户',
    questions: [
      ['BVI 进入 FATF 灰名单是不是不能开户？', '不是。灰名单意味着加强监控和尽职调查，不等于银行全面拒绝。合规客户需要准备更完整的 KYC、资金来源和架构说明。'],
      ['银行为什么会更严格？', '银行需要解释客户结构、资金来源、最终受益人、税务居民身份和交易目的。资料越清晰，账户越稳定。'],
    ],
  },
  {
    title: 'B+H 架构',
    questions: [
      ['B+H 是什么？', 'B+H = BVI 控股公司 + 香港运营或银行账户。BVI 做控股和隔离，香港承担银行、交易、运营和申报功能。'],
      ['B+H 和新加坡、香港是替代关系吗？', '不是简单替代。BVI、香港、新加坡各自功能不同。BVI 适合资产持有和隔离，香港和新加坡更适合运营、账户和区域业务。'],
      ['B+H 适合上市公司吗？', 'B+H 主要面向家办和财富保全，不是典型上市架构。拟上市企业通常还会考虑开曼、香港上市规则和中国备案要求。'],
    ],
  },
  {
    title: '中国法律衔接',
    questions: [
      ['中国税务居民能持有 BVI 公司吗？', '可以持有，但需要关注资金来源、外汇路径、税务居民身份、CFC 规则、实际管理机构和 CRS 信息一致性。'],
      ['ODI 和 37 号文与 BVI 有什么关系？', '企业出境投资通常关注 ODI，个人特殊目的公司安排通常关注 37 号文登记。BVI 常作为境外控股层的一环，但境内出境路径必须清楚。'],
      ['CRS 信息交换后，中国税务机关一定会查吗？', '不一定。税务机关更关注信息不一致、资金来源不清、未申报收入、未备案出境等风险点。合规用户的关键是资料一致和可解释。'],
    ],
  },
];
---

<BaseLayout title="BVI 2.0 FAQ | BVI.vg" description="BVI 2.0 常见问题：CRS 2.0、UBO、FATF、B+H 架构与中国法律衔接。">
  <div class="max-w-(--content-max-width) mx-auto px-6 py-10">
    <nav aria-label="面包屑" class="mb-6">
      <ol class="flex items-center gap-1.5 text-sm font-sans text-text-muted">
        <li><a href="/" class="hover:text-primary transition-colors">首页</a></li>
        <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li><a href="/bvi-2-0/" class="hover:text-primary transition-colors">BVI 2.0</a></li>
        <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-text-main">FAQ</li>
      </ol>
    </nav>

    <article class="prose">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-sans font-medium bg-secondary/10 text-secondary-dark mb-4">BVI 2.0 · FAQ</span>
      <h1>BVI 2.0 FAQ</h1>
      <p class="lead">把用户最常问的问题集中回答：CRS 2.0、UBO、FATF、B+H 架构与中国法律衔接。</p>

      <BVI20SectionNav />

      <div class="not-prose space-y-8 my-8">
        {groups.map((group) => (
          <section>
            <h2 class="font-sans text-2xl font-bold text-primary mb-4">{group.title}</h2>
            <div class="space-y-4">
              {group.questions.map(([q, a]) => (
                <details class="rounded-xl border border-border-main bg-bg-elevated p-5">
                  <summary class="cursor-pointer font-sans font-semibold text-text-main">{q}</summary>
                  <p class="text-sm text-text-muted leading-relaxed mt-4 mb-0">{a}</p>
                </details>
              ))}
            </div>
          </section>
        ))}
      </div>

      <h2>继续阅读</h2>
      <ul>
        <li><a href="/bvi-2-0/crs-2/">CRS 2.0 专题</a></li>
        <li><a href="/bvi-2-0/myths/">常见误读澄清</a></li>
        <li><a href="/bvi-2-0/china-connection/">与中国法律衔接</a></li>
      </ul>
    </article>

    <aside class="mt-12 p-5 rounded-lg bg-bg-muted border border-border-main text-sm text-text-muted" role="note">
      <p class="font-sans font-semibold text-text-main mb-2">免责声明</p>
      <p>本知识库提供通用信息，不构成法律意见。具体架构搭建请咨询 BVI 持牌律师、中国税务律师及外汇合规顾问。</p>
    </aside>
  </div>
</BaseLayout>
