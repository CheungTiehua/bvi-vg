---
import BaseLayout from '@layouts/BaseLayout.astro';
import BVI20SectionNav from '@components/BVI20SectionNav.astro';

const events = [
  { date: '2023.01', title: '经济实质法2.0', impact: '纯控股公司要求最低', action: '确认公司类型', what: 'BVI继续按活动类型区分经济实质义务，纯控股公司通常适用较轻要求。', who: '主要影响持有股权、基金份额或其他资产的BVI控股公司。', todo: '确认公司是否属于纯控股公司，并保存必要的股权管理与决策记录。' },
  { date: '2023.07', title: 'FAR年度财务申报', impact: '需提交财报（不公开）', action: '每年准备财报', what: 'BVI公司需要通过注册代理提交年度财务申报资料。', who: '绝大多数存续BVI公司都需要关注该年度维护义务。', todo: '按年度整理资产负债、收入支出及相关记录，配合注册代理提交。' },
  { date: '2024.02', title: 'FATF灰名单', impact: '银行开户审核加严', action: '准备更完整KYC', what: '灰名单意味着加强监控和整改，不等于黑名单或全面封禁。', who: '主要影响需要开户、续期KYC、跨境转账或银行关系维护的BVI架构用户。', todo: '提前准备资金来源、业务说明、架构图、UBO资料和税务居民身份说明。' },
  { date: '2025.01', title: '商业公司法案修订', impact: 'UBO门槛降至10%', action: '更新UBO登记', what: '持有BVI公司10%以上股份、投票权或控制权的自然人，需要向注册代理申报身份信息。', who: '影响持有10%-25%权益的小股东，以及原本未被纳入UBO登记范围的控制人。', todo: '联系注册代理，更新最终受益人登记资料。' },
  { date: '2026.01', title: 'CRS 2.0生效', impact: '加密资产纳入申报', action: '确认加密资产', what: 'CRS 2.0扩大自动信息交换范围，重点覆盖加密资产、双重身份和多层架构穿透。', who: '影响持有金融账户、托管账户、加密资产或多层控股架构的用户。', todo: '确认账户、托管平台、税务居民身份及控制人资料是否一致。' },
  { date: '2026.04', title: '正当利益查阅机制', impact: '25%以上可被查询', action: '无需主动行动', what: '第三方在满足正当利益、门槛和审查程序后，可申请查询部分受益所有权信息。', who: '主要影响持有BVI公司25%以上权益或控制权的实益拥有人。', todo: '保持登记资料准确，并理解查询不是公开查册，而是有条件、有限范围的查阅机制。' },
];

const caymanRows = [
  ['经济实质-控股公司', '要求最低', '要求较高'],
  ['UBO申报门槛', '10%', '10%'],
  ['UBO查询门槛', '25%+正当利益', '25%+正当利益'],
  ['年度申报', 'FAR（不公开）', '经济实质申报'],
  ['CRS 2.0落地', '2026.01', '2026.01'],
  ['FATF状态', '灰名单', '未列入'],
];
---

<BaseLayout title="法规更新追踪 | BVI 2.0 | BVI.vg" description="BVI 2.0法规时间轴：经济实质法2.0、FAR年度财务申报、FATF灰名单、UBO门槛、CRS 2.0与正当利益查阅机制。">
  <div class="max-w-(--content-max-width) mx-auto px-6 py-10">
    <nav aria-label="面包屑" class="mb-6"><ol class="flex items-center gap-1.5 text-sm font-sans text-text-muted"><li><a href="/" class="hover:text-primary transition-colors">首页</a></li><li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li><li><a href="/bvi-2-0/" class="hover:text-primary transition-colors">BVI 2.0</a></li><li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li><li class="text-text-main">法规更新追踪</li></ol></nav>

    <article class="prose">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-sans font-medium bg-secondary/10 text-secondary-dark mb-4">BVI 2.0 · P2</span>
      <h1>法规更新追踪</h1>
      <p class="lead">BVI法规在变，但方向是“规范”而不是“封禁”。BVI 2.0的核心不是退出离岸工具，而是在新透明规则下重建合规使用方式。</p>

      <BVI20SectionNav />

      <h2>时间轴</h2>
      <div class="not-prose space-y-5 my-8">
        {events.map((event) => (
          <section class="rounded-xl border border-border-main bg-bg-elevated p-6 hover:border-secondary/70 transition-colors">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between"><div><time class="font-sans text-sm font-semibold text-secondary-dark">{event.date}</time><h2 class="font-sans text-xl font-bold text-primary mt-1 mb-2">{event.title}</h2><p class="text-sm text-text-muted leading-relaxed mb-0">{event.impact}</p></div><div class="rounded-full bg-secondary/10 px-4 py-2 text-sm font-sans font-semibold text-secondary-dark shrink-0">{event.action}</div></div>
            <div class="grid gap-4 md:grid-cols-3 mt-5"><div class="rounded-lg bg-bg-muted p-4"><p class="font-sans text-sm font-semibold text-text-main mb-2">这是什么</p><p class="text-sm text-text-muted leading-relaxed mb-0">{event.what}</p></div><div class="rounded-lg bg-bg-muted p-4"><p class="font-sans text-sm font-semibold text-text-main mb-2">对谁有影响</p><p class="text-sm text-text-muted leading-relaxed mb-0">{event.who}</p></div><div class="rounded-lg bg-secondary/10 p-4"><p class="font-sans text-sm font-semibold text-text-main mb-2">需要做什么</p><p class="text-sm text-text-muted leading-relaxed mb-0">{event.todo}</p></div></div>
          </section>
        ))}
      </div>

      <h2>与开曼的合规对比</h2>
      <div class="overflow-x-auto"><table><thead><tr><th>维度</th><th>BVI</th><th>开曼</th></tr></thead><tbody>{caymanRows.map(([dimension, bvi, cayman]) => (<tr><td><strong>{dimension}</strong></td><td>{bvi}</td><td>{cayman}</td></tr>))}</tbody></table></div>

      <h2>可下载资源</h2>
      <ul><li>法规原文链接汇总：后续可外链到BVI FSC官网、BVI ITA及BVI Government公告。</li><li>关键法条中文翻译节选：建议后续优先翻译UBO条款、FAR申报条款、VISTA信托条款。</li></ul>
    </article>

    <aside class="mt-12 p-5 rounded-lg bg-bg-muted border border-border-main text-sm text-text-muted" role="note"><p class="font-sans font-semibold text-text-main mb-2">免责声明</p><p>本知识库提供通用信息，不构成法律意见。具体架构搭建请咨询BVI持牌律师。</p></aside>
  </div>
</BaseLayout>
