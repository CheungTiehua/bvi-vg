---
import BaseLayout from '@layouts/BaseLayout.astro';

const pillars = [
  {
    title: '法规更新追踪',
    eyebrow: 'REGULATION',
    href: '#pillars',
    description: '2025-2026 年 BVI 新规全解读，跟踪 UBO、FAR、CRS 2.0 与查阅机制。',
  },
  {
    title: 'CRS 2.0 专题',
    eyebrow: 'CRS 2.0',
    href: '#pillars',
    description: '厘清 CRS 2.0 是什么、不是什么，以及对合法商人的真实影响。',
  },
  {
    title: 'B+H 2.0 架构',
    eyebrow: 'B+H',
    href: '#pillars',
    description: 'BVI 控股公司 + 香港运营/银行账户，后 VIE 时代的家办标准配置。',
  },
  {
    title: '常见误读澄清',
    eyebrow: 'MYTHS',
    href: '#pillars',
    description: '针对市场上的恐慌言论，逐条拆解 BVI 2.0 的事实与边界。',
  },
];

const comparisons = [
  ['核心功能', '藏钱、避税', '资产保护、合规持有'],
  ['信息透明', '绝对保密', 'CRS 申报 + UBO 备案，第三方查询门槛 25%'],
  ['用户画像', '灰色资金', '合法合规的家族财富'],
  ['监管态度', '被打压', '合规后的幸存者'],
  ['核心价值', '“不被看见”', '“被看见也拿不走”'],
];
---

<BaseLayout title="BVI 2.0 | BVI.vg" description="BVI 2.0：合规时代的 BVI。不是藏钱，而是留钱；不是逃避监管，而是在透明时代完成资产保全。">
  <section class="relative overflow-hidden bg-primary text-white">
    <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_top_right,_#C6A43F,_transparent_35%),radial-gradient(circle_at_bottom_left,_#6B1D2F,_transparent_30%)]"></div>
    <div class="relative max-w-(--page-max-width) mx-auto px-6 py-24 md:py-32">
      <p class="font-sans text-sm tracking-[0.35em] uppercase text-secondary-light mb-5">BVI 2.0</p>
      <h1 class="font-sans text-5xl md:text-7xl font-bold leading-tight mb-6">合规时代的 BVI</h1>
      <p class="max-w-3xl text-2xl md:text-3xl leading-relaxed text-white/90 mb-10">不再是“藏钱”，而是“留钱”。</p>
      <a href="#pillars" class="inline-flex items-center rounded-md bg-secondary px-6 py-3 font-sans text-base font-semibold text-white hover:bg-secondary-light transition-colors">
        了解 BVI 2.0 的四大支柱
        <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
      </a>
    </div>
  </section>

  <div class="max-w-(--content-max-width) mx-auto px-6 py-12 md:py-16">
    <nav aria-label="面包屑" class="mb-8">
      <ol class="flex items-center gap-1.5 text-sm font-sans text-text-muted">
        <li><a href="/" class="hover:text-primary transition-colors">首页</a></li>
        <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-text-main">BVI 2.0</li>
      </ol>
    </nav>

    <article class="prose">
      <div class="not-prose rounded-2xl border border-border-main bg-bg-elevated p-6 md:p-8 shadow-sm mb-12">
        <p class="font-sans text-sm font-semibold text-secondary-dark mb-3">一句话定义</p>
        <h2 class="font-sans text-2xl md:text-3xl font-bold text-primary mb-4">BVI 2.0 = CRS 时代，家族财富保全的最优解。</h2>
        <p class="text-text-muted leading-relaxed mb-0">在信息透明成为全球共识的今天，BVI 的功能从“不被看见”升级为“被看见也拿不走”——通过 VISTA 信托、资产隔离、跨境合规架构，实现真正的财富保全。</p>
      </div>

      <h2>BVI 1.0 vs BVI 2.0</h2>
      <div class="overflow-x-auto">
        <table>
          <thead>
            <tr>
              <th>维度</th>
              <th>BVI 1.0（旧认知）</th>
              <th>BVI 2.0（新事实）</th>
            </tr>
          </thead>
          <tbody>
            {comparisons.map(([dimension, oldView, newFact]) => (
              <tr>
                <td><strong>{dimension}</strong></td>
                <td>{oldView}</td>
                <td>{newFact}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h2 id="pillars">四大支柱</h2>
      <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-5 my-8">
        {pillars.map((pillar) => (
          <a href={pillar.href} class="group block rounded-xl border border-border-main bg-bg-elevated p-6 hover:border-secondary hover:shadow-md transition-all">
            <p class="font-sans text-xs font-semibold tracking-[0.2em] text-secondary-dark mb-3">{pillar.eyebrow}</p>
            <h3 class="font-sans text-xl font-bold text-text-main group-hover:text-primary transition-colors mb-3">{pillar.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed mb-0">{pillar.description}</p>
          </a>
        ))}
      </div>

      <h2>关键结论</h2>
      <blockquote>
        CRS 2.0 对合法商人几乎没有影响。BVI 是目前少数合规可用的离岸工具。家办的核心是“留钱”不是“藏钱”——这一点从未改变。
      </blockquote>

      <div class="not-prose rounded-xl border border-secondary/30 bg-secondary/10 p-5 my-8">
        <p class="font-sans font-semibold text-primary mb-2">本文档最后审核</p>
        <p class="text-sm text-text-muted mb-0">2026-05-27 | 基于 BVI 2025-2026 年立法更新</p>
      </div>
    </article>

    <aside class="mt-12 p-5 rounded-lg bg-bg-muted border border-border-main text-sm text-text-muted" role="note">
      <p class="font-sans font-semibold text-text-main mb-2">免责声明</p>
      <p>本知识库提供通用信息，不构成法律意见。具体架构搭建请咨询 BVI 持牌律师。</p>
    </aside>
  </div>
</BaseLayout>
