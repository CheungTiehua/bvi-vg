import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="信托综合指南 | BVI.vg" description="BVI 信托法概述、信托类型全览（VISTA、普通、慈善、目的信托）及设立流程与税务处理指南。">
  <div class="max-w-(--content-max-width) mx-auto px-6 py-10">
    <nav aria-label="面包屑" class="mb-6">
      <ol class="flex items-center gap-1.5 text-sm font-sans text-text-muted">
        <li><a href="/" class="hover:text-primary transition-colors">首页</a></li>
        <li aria-hidden="true"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-text-main">信托综合指南</li>
      </ol>
    </nav>

    <article class="prose">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-sans font-medium bg-secondary/20 text-secondary-dark mb-4">横向专题</span>
      <h1>BVI 信托综合指南</h1>
      <p class="text-lg text-text-muted">从信托法基础到实务操作，全面解读 BVI 信托的类型、参与方角色、设立流程及税务处理。</p>

      <h2>BVI 信托法概述</h2>
      <p>BVI 信托法律制度以英国普通法为基础，主要法规包括：</p>
      <ul>
        <li><strong>《受托人法》</strong>（Trustee Act）：规定受托人的权力和义务</li>
        <li><strong>《维尔京群岛特别信托法案》</strong>（VISTA）：专门针对以 BVI 公司股权为信托财产的信托</li>
        <li><strong>《反永续法》</strong>（Perpetuities Act）：规定 BVI 信托的存续期最长可达 360 年</li>
      </ul>

      <h2>信托的核心要素</h2>
      <p>一个有效的 BVI 信托包含以下关键角色：</p>
      <p><strong>委托人（Settlor）</strong>——设立信托、将资产转移给受托人的个人或实体。委托人通常保留一定程度的控制权（通过意愿书或保护人机制）。</p>
      <p><strong>受托人（Trustee）</strong>——持有和管理信托资产的法律所有者。受托人对受益人负有信义义务（fiduciary duty），必须按照信托契约和法律规定行事。可以是 BVI 持牌信托公司、私人信托公司（PTC）或具有相应资质的个人。</p>
      <p><strong>受益人（Beneficiaries）</strong>——享有信托利益（收入或资本）的个人或实体。受益人对信托资产有受益权，但不是法律所有人。</p>
      <p><strong>保护人（Protector）</strong>——可选角色，通常拥有监督受托人、同意重大决策、更换受托人等权力。常由委托人的信赖顾问担任。</p>

      <h2>信托类型概览</h2>
      <table>
        <tr><th>类型</th><th>特征</th><th>适用场景</th></tr>
        <tr><td>全权信托（Discretionary Trust）</td><td>受托人拥有分配信托收入和资本的酌情权</td><td>家族财富传承、资产保护</td></tr>
        <tr><td>固定权益信托（Fixed Interest Trust）</td><td>受益人的权益比例固定</td><td>简单的代持安排</td></tr>
        <tr><td>VISTA 信托</td><td>受托人不干预公司管理，委托人保留控制权</td><td>家族企业股权信托</td></tr>
        <tr><td>慈善信托（Charitable Trust）</td><td>以慈善为目的，可永续存在</td><td>家族慈善基金会</td></tr>
        <tr><td>目的信托（Purpose Trust）</td><td>为特定目的（而非特定受益人）设立</td><td>持有特殊资产、PTC 股份</td></tr>
      </table>

      <h2>信托设立流程</h2>
      <ol>
        <li><strong>架构设计</strong>：明确信托目的、选择信托类型、确定参与方</li>
        <li><strong>起草信托契约</strong>：由 BVI 律师起草，涵盖受托人权力、分配机制、保护人权力、终止条件等</li>
        <li><strong>签署与交割</strong>：委托人和受托人签署信托契约，委托人将初始信托财产转移给受托人</li>
        <li><strong>后续管理</strong>：受托人按照信托契约管理资产、进行分配、保持账目记录</li>
      </ol>

      <h2>信托的税务处理</h2>
      <p>BVI 不对信托征收任何形式的所得税、资本利得税或遗产税。但是：</p>
      <ul>
        <li>信托受益人应根据其税务居民身份在各自国家申报信托分配</li>
        <li>信托持有的底层资产可能在资产所在国产生税务义务</li>
        <li>受托人（如为 BVI 持牌公司）需遵守 CRS 信息交换义务</li>
      </ul>

      <h2>信托的变更与终止</h2>
      <p>信托契约通常规定变更和终止的条件。常见方式包括：全体受益人一致同意终止、受托人行使酌情权终止、达到信托期限自动终止。BVI 信托最长可存续 360 年。</p>
    </article>

