---
import ThemeToggle from './ThemeToggle.astro';
import { TOPICS, TOPIC_LABELS, PHASE2_TOPICS, PHASE2_LABELS } from '@lib/constants';
---

<nav class="sticky top-0 z-40 bg-bg/90 backdrop-blur-md border-b border-border-main h-(--nav-height)" aria-label="主导航">
  <div class="max-w-(--page-max-width) mx-auto px-6 h-full flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="font-sans font-bold text-xl text-primary hover:text-primary-light transition-colors shrink-0">
      BVI.vg
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-1">
      <!-- Core Topics Dropdown -->
      <div class="relative group">
        <button class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors flex items-center gap-1" aria-expanded="false">
          核心专题
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="absolute top-full left-0 mt-1 w-72 bg-bg-elevated rounded-lg shadow-lg border border-border-main opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
          {TOPICS.map((slug) => (
            <a href={`/${slug}/`} class="block px-4 py-2.5 text-sm hover:bg-bg-muted transition-colors">
              <span class="font-sans font-medium text-text-main">{TOPIC_LABELS[slug]}</span>
            </a>
          ))}
          <div class="border-t border-border-light mx-4 my-2"></div>
          <p class="px-4 py-1 text-xs text-text-muted font-sans">深度专题</p>
          {PHASE2_TOPICS.map((slug) => (
            <a href={`/${slug}/`} class="block px-4 py-2 text-sm text-text-muted hover:bg-bg-muted transition-colors">
              {PHASE2_LABELS[slug]}
            </a>
          ))}
        </div>
      </div>

      <a href="/spc/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">SPC</a>
      <a href="/bc/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">BC</a>
      <a href="/vista/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">VISTA</a>
      <a href="/ptc/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">PTC</a>
      <a href="/diagnosis/" class="px-3 py-2 text-sm font-sans font-medium text-white bg-secondary rounded-md hover:bg-secondary-light transition-colors">自诊</a>
      <a href="/comparison/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">对比</a>
      <a href="/fees/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">费用</a>
      <a href="/faq/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">FAQ</a>
      <a href="/about/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">关于</a>
      <a href="/search/" class="px-3 py-2 text-sm font-sans font-medium text-text-main hover:text-primary rounded-md hover:bg-bg-muted transition-colors">搜索</a>
      <div class="ml-2">
        <ThemeToggle />
      </div>
    </div>

    <!-- Mobile hamburger -->
    <div class="lg:hidden flex items-center gap-2">
      <ThemeToggle />
      <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" />
      <label for="mobile-menu-toggle" class="p-2 cursor-pointer rounded-md hover:bg-bg-muted transition-colors" aria-label="菜单">
        <svg class="w-6 h-6 block peer-checked:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" /></svg>
        <svg class="w-6 h-6 hidden peer-checked:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </label>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="lg:hidden hidden peer-checked:block absolute top-(--nav-height) left-0 right-0 bg-bg-elevated border-b border-border-main shadow-lg">
    <div class="px-6 py-4 space-y-1">
      <p class="text-xs font-sans font-semibold uppercase text-text-muted mb-2">核心专题</p>
      {TOPICS.map((slug) => (
        <a href={`/${slug}/`} class="block px-3 py-2.5 text-sm font-medium rounded-md hover:bg-bg-muted transition-colors">{TOPIC_LABELS[slug]}</a>
      ))}
      <div class="border-t border-border-light my-2"></div>
      <p class="text-xs font-sans font-semibold uppercase text-text-muted mb-2">深度专题</p>
      {PHASE2_TOPICS.map((slug) => (
        <a href={`/${slug}/`} class="block px-3 py-2 text-sm text-text-muted rounded-md hover:bg-bg-muted transition-colors">{PHASE2_LABELS[slug]}</a>
      ))}
      <div class="border-t border-border-light my-2"></div>
      <a href="/about/" class="block px-3 py-2.5 text-sm font-medium rounded-md hover:bg-bg-muted transition-colors">关于本站</a>
      <a href="/search/" class="block px-3 py-2.5 text-sm font-medium rounded-md hover:bg-bg-muted transition-colors">搜索</a>
    </div>
  </div>
</nav>
