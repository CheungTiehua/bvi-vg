<div id="bvi-chat" class="fixed bottom-6 right-6 z-50 font-sans">
  <button
    id="bvi-chat-toggle"
    type="button"
    class="flex h-14 w-14 items-center justify-center rounded-full bg-secondary text-white shadow-lg transition-transform hover:scale-105 hover:bg-secondary-light"
    aria-label="打开 BVI AI 助手"
    aria-expanded="false"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21 15a2 2 0 01-2 2H8l-5 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
    </svg>
  </button>

  <section
    id="bvi-chat-panel"
    class="hidden absolute bottom-20 right-0 h-[560px] max-h-[calc(100vh-8rem)] w-[380px] max-w-[calc(100vw-3rem)] overflow-hidden rounded-2xl border border-border-main bg-bg-elevated shadow-2xl"
    aria-label="BVI AI 助手"
  >
    <div class="flex h-full flex-col">
      <header class="flex items-start justify-between bg-primary px-5 py-4 text-white">
        <div>
          <h2 class="text-sm font-semibold">BVI AI 助手</h2>
          <p class="mt-1 text-xs text-white/70">优先检索 BVI.vg 知识库 · DeepSeek + Tavily</p>
        </div>
        <button id="bvi-chat-close" type="button" class="rounded-md p-1 text-white/70 hover:bg-white/10 hover:text-white" aria-label="关闭 BVI AI 助手">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </header>

      <div id="bvi-chat-messages" class="flex-1 space-y-4 overflow-y-auto px-4 py-4 text-sm">
        <div class="flex justify-start">
          <div class="max-w-[86%] rounded-2xl rounded-bl-md bg-bg-muted px-4 py-2.5 text-text-main">
            你好。我可以帮你理解 BVI 2.0、CRS、UBO、B+H 架构、VISTA 信托和中国法律衔接。仅供一般信息参考，不构成法律、税务或投资意见。
          </div>
        </div>
      </div>

      <div class="border-t border-border-main px-4 py-3">
        <p class="mb-2 text-[11px] leading-relaxed text-text-muted">AI 回答仅作知识库检索和一般说明；具体架构、税务、外汇、开户或信托安排请咨询持牌专业人士。</p>
        <div class="mb-2 flex flex-wrap gap-2 text-xs">
          <button type="button" data-bvi-prompt="CRS 2.0 对 BVI 公司有什么影响？" class="rounded-full bg-bg-muted px-3 py-1 text-text-muted hover:text-primary">CRS 2.0</button>
          <button type="button" data-bvi-prompt="B+H 架构适合什么人？" class="rounded-full bg-bg-muted px-3 py-1 text-text-muted hover:text-primary">B+H</button>
          <button type="button" data-bvi-prompt="BVI 信息现在是不是全部公开？" class="rounded-full bg-bg-muted px-3 py-1 text-text-muted hover:text-primary">UBO</button>
        </div>
        <div class="flex gap-2">
          <input
            id="bvi-chat-input"
            type="text"
            class="min-w-0 flex-1 rounded-xl border border-border-main bg-bg px-3 py-2 text-sm text-text-main outline-none transition-colors focus:border-secondary disabled:opacity-60"
            placeholder="输入你的问题…"
            autocomplete="off"
          />
          <button
            id="bvi-chat-send"
            type="button"
            class="rounded-xl bg-secondary px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-secondary-light disabled:cursor-not-allowed disabled:opacity-50"
          >
            发送
          </button>
        </div>
      </div>
    </div>
  </section>
</div>

<script is:inline>
  (function () {
    const root = document.getElementById('bvi-chat');
    if (!root) return;

    const toggle = document.getElementById('bvi-chat-toggle');
    const panel = document.getElementById('bvi-chat-panel');
    const close = document.getElementById('bvi-chat-close');
    const messagesEl = document.getElementById('bvi-chat-messages');
    const input = document.getElementById('bvi-chat-input');
    const send = document.getElementById('bvi-chat-send');
    const quickButtons = root.querySelectorAll('[data-bvi-prompt]');

    let messages = [];
    let loading = false;

    function setOpen(open) {
      panel.classList.toggle('hidden', !open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) setTimeout(() => input.focus(), 50);
    }

    function scrollToBottom() {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function addBubble(role, content) {
      const wrap = document.createElement('div');
      wrap.className = role === 'user' ? 'flex justify-end' : 'flex justify-start';

      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[86%] rounded-2xl rounded-br-md bg-secondary px-4 py-2.5 text-white whitespace-pre-wrap'
        : 'max-w-[86%] rounded-2xl rounded-bl-md bg-bg-muted px-4 py-2.5 text-text-main whitespace-pre-wrap';
      bubble.textContent = content;

      wrap.appendChild(bubble);
      messagesEl.appendChild(wrap);
      scrollToBottom();
      return bubble;
    }

    function setLoading(next) {
      loading = next;
      send.disabled = next || !input.value.trim();
      input.disabled = next;
    }

    async function handleSend(text) {
      const content = (text || input.value).trim();
      if (!content || loading) return;

      setOpen(true);
      input.value = '';
      addBubble('user', content);
      messages.push({ role: 'user', content });
      setLoading(true);

      const assistantBubble = addBubble('assistant', '');
      let fullContent = '';

      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages }),
        });

        if (!response.ok) {
          const data = await response.json().catch(() => ({}));
          throw new Error(data.error || 'AI 助手暂时不可用。');
        }

        const reader = response.body && response.body.getReader();
        if (!reader) throw new Error('AI 助手没有返回内容。');

        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const result = await reader.read();
          if (result.done) break;
          buffer += decoder.decode(result.value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';

          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed.startsWith('data: ')) continue;
            const data = trimmed.slice(6);
            if (data === '[DONE]') continue;
            try {
              const parsed = JSON.parse(data);
              const delta = parsed.choices && parsed.choices[0] && parsed.choices[0].delta && parsed.choices[0].delta.content;
              if (delta) {
                fullContent += delta;
                assistantBubble.textContent = fullContent;
                scrollToBottom();
              }
            } catch (_) {}
          }
        }

        if (!fullContent) fullContent = '我没有拿到有效回答。请换个问法再试。';
        assistantBubble.textContent = fullContent;
        messages.push({ role: 'assistant', content: fullContent });
        messages = messages.slice(-10);
      } catch (error) {
        assistantBubble.textContent = error && error.message ? error.message : 'AI 助手暂时不可用。';
      } finally {
        setLoading(false);
      }
    }

    toggle.addEventListener('click', () => setOpen(panel.classList.contains('hidden')));
    close.addEventListener('click', () => setOpen(false));
    send.addEventListener('click', () => handleSend());
    input.addEventListener('input', () => { send.disabled = loading || !input.value.trim(); });
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        handleSend();
      }
    });

    quickButtons.forEach((button) => {
      button.addEventListener('click', () => handleSend(button.getAttribute('data-bvi-prompt') || ''));
    });

    send.disabled = true;
  })();
</script>
